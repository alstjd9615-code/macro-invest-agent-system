# =============================================================================
# macro-invest-agent-platform  —  environment variable template
# =============================================================================
# Copy this file to .env and fill in values for your local environment.
# The .env file is gitignored and must never be committed.
#
# Variable naming conventions:
#   APP_*        → application-level settings
#   DATABASE_*   → PostgreSQL connection settings
#   MINIO_*      → MinIO / S3-compatible object store settings
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Running environment. Valid values: local | test | staging | production
APP_ENV=local

# Log level. Valid values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# Set to "true" to emit pretty-printed (human-readable) logs instead of JSON.
LOG_PRETTY=true

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------

# Full connection URL used by SQLAlchemy / Alembic.
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg://macro_user:macro_pass@localhost:5432/macro_db

POSTGRES_USER=macro_user
POSTGRES_PASSWORD=macro_pass
POSTGRES_DB=macro_db

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object store)
# ---------------------------------------------------------------------------

# MinIO API endpoint (used by boto3 / aiobotocore).
MINIO_ENDPOINT=http://localhost:9000

# Root (admin) credentials — for local development only.
# Never use these values in production.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Default bucket for raw macro data artefacts.
MINIO_BUCKET_RAW=macro-raw

# ---------------------------------------------------------------------------
# Secrets (never log these values)
# ---------------------------------------------------------------------------

# Example: API key placeholder for future external data providers.
# MACRO_DATA_API_KEY=your-api-key-here
