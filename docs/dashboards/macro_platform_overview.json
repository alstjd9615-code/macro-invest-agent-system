      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (tool, le) (rate(macro_platform_mcp_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "{{tool}} p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (tool, le) (rate(macro_platform_mcp_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "{{tool}} p99",
          "refId": "B"
        }
      ],
      "title": "MCP Tool Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Provider Fetches",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (provider, result) (rate(macro_platform_provider_fetch_total[5m]))",
          "legendFormat": "{{provider}} {{result}}",
          "refId": "A"
        }
      ],
      "title": "Provider Fetch Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(macro_platform_provider_fetch_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (provider, le) (rate(macro_platform_provider_fetch_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} p99",
          "refId": "B"
        }
      ],
      "title": "Provider Fetch Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103,
      "title": "Ingestion Pipeline",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
