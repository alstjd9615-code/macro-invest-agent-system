      "id": 9,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (source, le) (rate(macro_platform_pipeline_run_duration_seconds_bucket[30m])))",
          "legendFormat": "{{source}} p95",
          "refId": "A"
        }
      ],
      "title": "Pipeline Run Duration p95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
