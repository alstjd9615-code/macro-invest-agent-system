{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Macro-invest-agent-platform — runtime health, latency, and pipeline status.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Agent Runtime",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (operation) (rate(macro_platform_agent_requests_total{result=\"success\"}[5m]))",
          "legendFormat": "{{operation}} success",
          "refId": "A"
        },
        {
          "expr": "sum by (operation) (rate(macro_platform_agent_requests_total{result=\"failure\"}[5m]))",
          "legendFormat": "{{operation}} failure",
          "refId": "B"
        }
      ],
      "title": "Agent Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (operation, le) (rate(macro_platform_agent_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{operation}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(macro_platform_agent_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{operation}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (operation, le) (rate(macro_platform_agent_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{operation}} p99",
          "refId": "C"
        }
      ],
      "title": "Agent Response Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "increase(macro_platform_schema_validation_failures_total[10m])",
          "legendFormat": "{{response_type}}",
          "refId": "A"
        }
      ],
      "title": "Schema Validation Failures (last 10 m)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 101,
      "title": "MCP Tools",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "sum by (tool, result) (rate(macro_platform_mcp_tool_calls_total[5m]))",
          "legendFormat": "{{tool}} {{result}}",
          "refId": "A"
        }
      ],
      "title": "MCP Tool Call Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
